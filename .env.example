# flow-designer server-only environment.
#
# Copy to `.env` and fill in real values. `.env` is gitignored; this template is not.
# Every name below is SERVER-ONLY. Never prefix any of these with `VITE_` — that would
# inline the value into the browser bundle. The Atlas bearer token never reaches the browser.

# Private Atlas origin, reachable from the flow-designer server only.
# Local development (the Atlas default):
ATLAS_API_ORIGIN=http://127.0.0.1:8787
# Production: TODO — the private origin is not decided yet (docs/CONFIGURATION.md §3).
# Example shape only, do not deploy as-is: http://atlas-internal:8787

# Seals the flow-designer session cookie. Minimum 32 characters.
# Generate one with:  openssl rand -base64 48
# Rotating this value invalidates every active session and forces re-login (by design).
SESSION_SECRET=replace-me-with-at-least-32-random-characters

# This app's own public origin, used for the CSRF origin check and absolute redirects.
# Local development:
PUBLIC_ORIGIN=http://localhost:3000
# Production: TODO — the public origin is not decided yet (docs/CONFIGURATION.md §2).
# Example shape only, do not deploy as-is: https://atlas.example.com

# Set this explicitly in the deployment environment. Local development defaults to
# development when it is absent; production additionally requires an https PUBLIC_ORIGIN.
# NODE_ENV=production

# Optional. Session cookie lifetime in seconds. Defaults to 28800 (8 hours).
# SESSION_MAX_AGE=28800
